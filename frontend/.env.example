# Frontend config (Vite reads VITE_* at build/dev time).

# API base. Default uses the Vite dev-server proxy (/api -> backend:8000).
# Set to an absolute URL if you serve the API elsewhere.
VITE_API_BASE=/api

# Stripe publishable (test) key, for the Stripe Elements enhancement.
# pk_test_... — safe to expose to the browser; the secret key stays server-side.
VITE_STRIPE_PUBLISHABLE_KEY=
