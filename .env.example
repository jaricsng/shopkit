# Copy to `.env` (which is git-ignored) and fill in real values locally.
# This file is the contract: it documents every env var the service reads,
# WITHOUT any real secret in version control. The pre-commit secret-scan
# hook + tools/doctor.py's secrets check both assume real values live only
# in `.env`, never here.
#
# Names below mirror what examples/minimal-service and ci-cd/.../ci.yml
# already use — adjust to your service.

# --- Core ---
ENVIRONMENT=development
APP_PORT=8000

# --- Secrets (generate your own; NEVER commit the real values) ---
# e.g. `openssl rand -hex 32`
SECRET_KEY=replace-with-a-local-dev-only-random-string

# --- Database ---
DATABASE_URL=postgresql+asyncpg://appuser:apppass@localhost:5432/appdb

# --- Observability (point at the local stack from `make obs-up`) ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=app
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
