# Copy to .env (git-ignored) for local non-Docker runs. Docker Compose sets
# these via its own `environment:` block, so you don't need .env to use compose.

# Database — Postgres in real runs; SQLite is handy for a quick local spin-up.
DATABASE_URL=postgresql+psycopg://shopkit:shopkit@localhost:5432/shopkit

# Auth — generate a real one: `python -c "import secrets; print(secrets.token_urlsafe(32))"`
SECRET_KEY=change-me-to-a-32-byte-or-longer-random-string
ACCESS_TOKEN_TTL_MINUTES=60

# Stripe (test mode). Leave blank to use the offline stub checkout.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenTelemetry — point at the observability overlay's Jaeger.
OTEL_ENABLED=true
OTEL_SERVICE_NAME=shopkit
OTLP_ENDPOINT=http://localhost:4317
# Emit the stable (1.23+) HTTP metric names/labels the Grafana dashboard uses.
# See observability/METRIC-NAME-DECISION.md.
OTEL_SEMCONV_STABILITY_OPT_IN=http

# Feature flags (Module 08). Default on; flip to false to dark-ship checkout.
FEATURE_CHECKOUT_ENABLED=true
